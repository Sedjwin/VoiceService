[Unit]
Description=VoiceService — STT/TTS audio pipeline
After=network-online.target

[Service]
Type=simple
User=sedjwin
Group=sedjwin
WorkingDirectory=/home/sedjwin/VoiceService
ExecStart=/home/sedjwin/VoiceService/.venv/bin/uvicorn app.main:app \
    --host 127.0.0.1 \
    --port 8002 \
    --log-level info
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=voiceservice

[Install]
WantedBy=multi-user.target
