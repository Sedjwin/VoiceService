# VoiceService — pure audio service, no AIGateway or LLM settings needed.
# All orchestration is handled by AIGateway.

HOST=0.0.0.0
PORT=13372

# STT model (downloads automatically on first use)
WHISPER_MODEL=base.en         # tiny.en | base.en | small.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8     # int8 is efficient on Raspberry Pi 5 ARM

# Default TTS voice
DEFAULT_VOICE=glados           # glados | atlas | jarvis | tars | terminator

# ESP32 pre-buffer hint (ms before starting I2S playback)
BUFFER_HINT_MS=500
