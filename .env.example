# VoiceService configuration — copy to .env and fill in values

# ── Networking ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=13372

# ── AIGateway connection ─────────────────────────────────────────────────────
AIGATEWAY_URL=http://localhost:13371
AIGATEWAY_API_KEY=your-agent-api-key-here   # Bearer token for an AIGateway agent

# ── LLM defaults (overridable per-request) ───────────────────────────────────
LLM_MODEL=                    # empty = gateway picks default / auto-routes
LLM_MAX_TOKENS=200
LLM_TEMPERATURE=0.8
LLM_SYSTEM_PROMPT=            # leave empty to use built-in GLaDOS personality

# ── STT ──────────────────────────────────────────────────────────────────────
WHISPER_MODEL=base.en         # tiny.en | base.en | small.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8     # int8 is efficient on ARM/Pi 5

# ── TTS ──────────────────────────────────────────────────────────────────────
DEFAULT_VOICE=glados           # glados | atlas

# ── ESP32 buffer hint ────────────────────────────────────────────────────────
BUFFER_HINT_MS=500            # ms to pre-buffer before playback starts
